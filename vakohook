    ESPTab:CreateToggle({Name = "Видеть сумки", Default = false, Callback = function(v) bagsEnabled = v; end});
    ESPTab:CreateToggle({Name = "Ящики с хабаром", Default = false, Callback = function(v) cratesEnabled = v; end});
    ESPTab:CreateToggle({Name = "Дистанция до чушпанов", Default = false, Callback = function(v) distEnabled = v; end});

    PerformanceTab:CreateSection("Шустрый софт | Оптимизация");
    PerformanceTab:CreateToggle({Name = "Разогнать облака", Default = false, Callback = function(v) --[[ логика удаления облаков ]] end});
    PerformanceTab:CreateToggle({Name = "Вырвать траву (FPS Boost)", Default = false, Callback = function(v) --[[ логика удаления травы ]] end});
    PerformanceTab:CreateToggle({Name = "Убрать листья", Default = false, Callback = function(v) --[[ логика удаления листьев ]] end});

    WorldTab:CreateSection("Мутки | Мир");
    WorldTab:CreateToggle({Name = "Фонарик в глаза (Fullbright)", Default = false, Callback = function(v) _G.FullBrightEnabled = v; end});
    
    FreecamTab:CreateSection("Приколюхи | Свободный полет");
    FreecamTab:CreateToggle({Name = "Врубить духа пацана", Default = false, Callback = function(v) freecamEnabled = v; end});
    FreecamTab:CreateKeybind({Name = "Кнопка полета", Default = Enum.KeyCode.K, Callback = function() toggleFreecam(); end});

    -- [ ТУТ ИДЕТ ВСЯ ТВОЯ ЛОГИКА ОБНОВЛЕНИЯ (RenderStepped, Heartbeat и т.д.) ]
    -- Я её не менял, чтобы всё работало как в оригинале [cite: 343, 353]
    
    RunService.RenderStepped:Connect(function(dt)
        if aimbotEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local target = getClosestPlayerToCursor();
            if target then
                local tPos = Camera:WorldToViewportPoint(target.Position);
                local mPos = Camera.ViewportSize / 2;
                mousemoverel((tPos.X - mPos.X) * aimbotSmoothing, (tPos.Y - mPos.Y) * aimbotSmoothing);
            end
        end
        fovCircle.Visible = showFOV;
        fovCircle.Position = Camera.ViewportSize / 2;
    end);
    
    -- ... (остальной твой оригинальный код обновлений из файла)
end
