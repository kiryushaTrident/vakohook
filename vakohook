-- [[ ВАРЕНЫЕ КОЛБАСКИ HOOK v1.0 | Trident Survival ]] --
-- [[ ЧИСТО ДЛЯ ПАЦАНОВ С РАЁНА ]] --

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "🌭 ВАРЕНЫЕ КОЛБАСКИ HOOK 🌭",
   LoadingTitle = "Греем колбаски...",
   LoadingSubtitle = "от Кирюши для пацанов",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "VakohookData",
      FileName = "PatsanCfg"
   }
})

-- Вкладка со стрельбой
local AimTab = Window:CreateTab("🎯 Стрелялка чоткая", 4483345998)

AimTab:CreateToggle({
   Name = "Врубить самонаводку на лоха (Aimbot)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AimEnabled = Value
   end,
})

AimTab:CreateSlider({
   Name = "Зоркость пацанская (FOV)",
   Range = {0, 500},
   Increment = 10,
   Suffix = " пикселей",
   CurrentValue = 100,
   Callback = function(Value)
      _G.AimFOV = Value
   end,
})

AimTab:CreateToggle({
   Name = "Спрятать круг (Hidden FOV)",
   CurrentValue = true,
   Callback = function(Value)
      _G.HideFOV = Value -- Твоя фишка для видео без мыла и палева
   end,
})

AimTab:CreateSlider({
   Name = "Чтобы не палиться (Smoothing)",
   Range = {1, 20},
   Increment = 1,
   Suffix = " плавность",
   CurrentValue = 5,
   Callback = function(Value)
      _G.AimSmooth = Value
   end,
})

-- Вкладка с ВХ
local VisualsTab = Window:CreateTab("👁️ Палилово терпил", 4483345998)

VisualsTab:CreateToggle({
   Name = "Квадраты вокруг чушпанов (Boxes)",
   CurrentValue = false,
   Callback = function(Value)
      _G.EspBoxes = Value
   end,
})

VisualsTab:CreateToggle({
   Name = "Цветные лохи (Chams)",
   CurrentValue = false,
   Callback = function(Value)
      _G.EspChams = Value
   end,
})

VisualsTab:CreateToggle({
   Name = "Погоняла и кликухи (Names)",
   CurrentValue = false,
   Callback = function(Value)
      _G.EspNames = Value
   end,
})

-- Вкладка с приколами
local MiscTab = Window:CreateTab("🏃 Мутки на раёне", 4483345998)

MiscTab:CreateButton({
   Name = "Бег от ментов (Speedhack)",
   Callback = function()
      game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 50
   end,
})

MiscTab:CreateButton({
   Name = "Ствол ровно (No Recoil)",
   Callback = function()
      -- Тут твоя магия для Trident Survival
      Rayfield:Notify({Title = "Расклад!", Content = "Отдача пошла нафиг", Duration = 3})
   end,
})

-- Выход
local ConfigTab = Window:CreateTab("⚙️ Свалить с хаты", 4483345998)

ConfigTab:CreateButton({
   Name = "Выгрузить колбаски (Unload)",
   Callback = function()
      Rayfield:Destroy()
   end,
})

Rayfield:Notify({
   Title = "Маза забита!",
   Content = "Вареные Колбаски Hook запущены. Удачного рейда!",
   Duration = 5,
   Image = 4483345998,
})
